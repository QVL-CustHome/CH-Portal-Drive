{
  "name": "ch-portal-drive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/sync-ui-lib.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-ui-lib.mjs",
    "build": "tsc -b && vite build",
    "sync:ui": "node scripts/sync-ui-lib.mjs",
